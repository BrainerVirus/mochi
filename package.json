{
  "name": "mochi",
  "version": "0.2.5",
  "private": true,
  "description": "Cross-platform desktop companion for tracking AI coding tool usage — tray, widget, settings, and CLI.",
  "keywords": [
    "ai",
    "ai-coding",
    "claude",
    "codex",
    "cursor",
    "desktop-app",
    "mochi",
    "react",
    "tanstack-router",
    "tauri",
    "tray-app",
    "usage-tracker"
  ],
  "homepage": "https://github.com/BrainerVirus/mochi#readme",
  "bugs": {
    "url": "https://github.com/BrainerVirus/mochi/issues"
  },
  "license": "MIT",
  "author": "Cristhofer Pincetti <86972354+BrainerVirus@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrainerVirus/mochi.git"
  },
  "type": "module",
  "scripts": {
    "build": "vite build && tsc --noEmit",
    "check:diagnostics-cli": "cargo run --quiet --manifest-path src-tauri/Cargo.toml -- diagnostics",
    "check:tauri-frontend": "node scripts/check-tauri-frontend-dist.mjs",
    "dev": "vite dev --port 1420",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --type-aware --react-plugin --jsx-a11y-plugin --import-plugin --deny-warnings app src",
    "preview": "vite preview",
    "start": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "MOCHI_DEV_SHOW_MAIN=1 pnpm tauri dev",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:release": "vitest run scripts/release/*.test.mjs",
    "test:scripts": "vitest run --config vitest.config.ts scripts/",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@gsap/react": "^2.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "^1.170.6",
    "@tanstack/router-plugin": "^1.168.9",
    "@tauri-apps/api": "^2.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^0.511.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@rolldown/plugin-babel": "0.2.3",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/react": "^16.0.0",
    "@types/babel__core": "7.20.5",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "3.2.4",
    "babel-plugin-react-compiler": "1.0.0",
    "happy-dom": "^15.0.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tailwindcss": "^0.8.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.13",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.15.0 <10"
  },
  "packageManager": "pnpm@9.15.9"
}
