{
  "name": "mochi",
  "version": "0.1.0",
  "private": true,
  "description": "Soft alerts before hard limits.",
  "type": "module",
  "scripts": {
    "build": "vite build && tsc --noEmit",
    "dev": "vite dev --port 1420",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --type-aware --react-plugin --jsx-a11y-plugin --import-plugin --deny-warnings app src",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "tauri": "tauri",
    "test": "vitest run"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "^1.170.6",
    "@tanstack/react-start": "^1.168.9",
    "@tanstack/router-plugin": "^1.168.9",
    "@tauri-apps/api": "^2.11.0",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^0.511.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tailwindcss": "^0.8.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.13",
    "vitest": "^3.2.1"
  }
}
